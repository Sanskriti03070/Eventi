{
  "project_name": "Eventi",
  "theme": "light",
  "typography": {
    "font_family": {
      "body": "DM Sans, sans-serif",
      "heading": "DM Sans, sans-serif",
      "logo": "Anonymous Pro, monospace"
    },
    "scale": {
      "h1": "text-3xl font-bold tracking-tight",
      "h2": "text-2xl font-semibold tracking-tight",
      "h3": "text-xl font-semibold",
      "body": "text-base font-normal leading-relaxed",
      "small": "text-sm font-medium text-muted-foreground"
    }
  },
  "colors": {
    "primary": "#DC143C",
    "primary_foreground": "#FFFFFF",
    "background": "#FFFFFF",
    "foreground": "#000000",
    "card": "#FFFFFF",
    "card_foreground": "#000000",
    "muted": "#F3F4F6",
    "muted_foreground": "#6B7280",
    "border": "#E5E7EB",
    "input": "#F3F4F6",
    "ring": "#DC143C",
    "destructive": "#EF4444",
    "success": "#22C55E"
  },
  "visual_enhancers": {
    "radius": "12px",
    "shadow": {
      "card": "0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1)",
      "hover": "0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1)"
    },
    "animation": {
      "none": "none",
      "fast": "transition-all duration-200 ease-in-out"
    }
  },
  "layout": {
    "container": "max-w-md mx-auto min-h-screen bg-background relative pb-20",
    "grid": {
      "mobile": "grid-cols-1 gap-4",
      "tablet": "md:grid-cols-2 md:gap-6",
      "desktop": "lg:grid-cols-3 lg:gap-8"
    },
    "spacing": {
      "section": "py-6 px-4",
      "card_padding": "p-4"
    }
  },
  "component_rules": {
    "buttons": {
      "primary": "bg-[#DC143C] text-white hover:bg-[#B01030] rounded-[12px] h-12 font-medium px-6",
      "secondary": "bg-white text-black border border-gray-200 hover:bg-gray-50 rounded-[12px] h-12 font-medium px-6",
      "ghost": "hover:bg-gray-100 text-gray-600 rounded-[12px] h-10 px-4",
      "destructive": "bg-red-500 text-white hover:bg-red-600 rounded-[12px] h-12"
    },
    "cards": {
      "default": "bg-white rounded-[12px] border border-gray-100 shadow-sm overflow-hidden",
      "interactive": "bg-white rounded-[12px] border border-gray-100 shadow-sm hover:shadow-md transition-shadow cursor-pointer overflow-hidden"
    },
    "inputs": {
      "default": "bg-gray-50 border-gray-200 focus:border-[#DC143C] focus:ring-[#DC143C] rounded-[12px] h-12 px-4"
    }
  },
