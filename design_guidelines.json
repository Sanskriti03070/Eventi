  "instructions_to_main_agent": [
    "1. MOBILE-FIRST: Build everything assuming a mobile viewport first (max-w-md mx-auto for desktop view).",
    "2. BRANDING: Use Primary Red #DC143C for all primary actions (Book, Pay, Login).",
    "3. TYPOGRAPHY: Import DM Sans from Google Fonts for the entire app. Use Anonymous Pro ONLY for the text 'Eventi' in the logo.",
    "4. COMPONENTS: Use Shadcn/UI components but override rounded corners to 12px (rounded-xl) and use light shadows.",
    "5. MOCKED FLOWS: Implement a simple 'Sign in with Google' button that mocks a successful login. Implement a 'Pay Now' button that opens a mock success modal.",
    "6. ADMIN PANEL: Create a separate /admin route. It does not need the mobile wrapper constraint; it can be full-width.",
    "7. DATA-TESTID: Add data-testid='...' to all interactive elements (buttons, inputs, cards).",
    "8. NO ANIMATIONS: Keep transitions minimal as requested (fast 200ms or none).",
    "9. ICONS: Use Lucide React icons. Simple, outlined style.",
    "10. SPLASH SCREEN: Create a splash screen with Red background and White 'Eventi' text (Anonymous Pro font) that shows for 2 seconds before redirecting to Login.",
    "11. COLOR PALETTE: Ensure high contrast. Text on Red buttons must be White. Text on White cards must be Black or Dark Gray."
  ],
  "universal_guidelines": [
    "Use 'sonner' for toasts.",
    "Do not use gradients for backgrounds, stick to solid White or subtle Gray #F9FAFB.",
    "Use lucide-react for icons.",
    "Export components as named exports.",
    "Export pages as default exports."
  ]
}